
# ghostty +list-keybinds --default
# ghostty +show-config --default --docs

theme = Atom

font-size = 15
font-family="FiraCode Nerd Font Mono"
font-thicken=true

window-height=30
window-width=130
background-opacity = 0.96

confirm-close-surface=false

# Keybinds
keybind = cmd+u=toggle_background_opacity

# Navigate splits
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom	
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

# Scroll
keybind = ctrl+alt+arrow_up=scroll_page_lines:-5 
keybind = ctrl+alt+arrow_down=scroll_page_lines:5 
keybind = ctrl+alt+page_up=scroll_page_lines:-25
keybind = ctrl+alt+page_down=scroll_page_lines:25 

