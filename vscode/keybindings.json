// Place your key bindings in this file to override the defaults
[
  // SUGGESTIONS
  {
    // Go to the new line instead of accepting suggestions 
    "key": "enter",
    "command": "type",
    "args": { "text": "\n" },
    "when": "editorTextFocus && (suggestWidgetVisible || github.copilot.inlineSuggestionVisible)"
  },
  {
    // Accept suggestions with Tab
    "key": "tab",
    "command": "acceptSelectedSuggestion",
    "when": "editorTextFocus && (suggestWidgetVisible || github.copilot.inlineSuggestionVisible)"
  },
  {
    // Close suggestions without exiting Vim insert mode
    "key": "escape",
    "command": "hideSuggestWidget",
    "when": "editorTextFocus && (suggestWidgetVisible || github.copilot.inlineSuggestionVisible)"
  },
  // FILE TREE
  {
    "command": "workbench.action.toggleSidebarVisibility",
    "key": "ctrl+e"
  },
  {
    "command": "workbench.files.action.focusFilesExplorer",
    "key": "ctrl+e",
    "when": "editorTextFocus"
  },
  {
    "key": "n",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "command": "renameFile",
    "key": "r",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "shift+n",
    "command": "explorer.newFolder",
    "when": "explorerViewletFocus"
  },
  {
    "command": "deleteFile",
    "key": "d",
    "when": "filesExplorerFocus && !inputFocus"
  },
  // TERMINAL
  {
    "key": "ctrl+alt+j",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  {
    "key": "ctrl+alt+n",
    "command": "workbench.action.terminal.new"
  },
  {
    "key": "ctrl+alt+p",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+alt+o",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+alt+r",
    "command": "workbench.action.terminal.rename",
    "when": "terminalFocus"
  },
  // COPILOT
  {
    "key": "ctrl+alt+h",
    "command": "workbench.action.chat.open",
    "when": "!chatSetupDisabledInWorkspace && !chatSetupHidden" },
  {
    "key": "ctrl+alt+h",
    "command": "workbench.action.closeSidebar",
    "when": "!editorFocus"
  },
  {
    "key": "ctrl+alt+y",
    "command": "github.copilot.completions.toggle"
  },
  // EXTRA
  {
    "key": "ctrl+w",
    "command": "workbench.action.closeActiveEditor",
    "when": "editorTextFocus"
  },
  {
    // Move line down
    "key": "alt+shift+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    // Move line up
    "key": "alt+shift+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+z",
    "command": "workbench.action.toggleZenMode"
  },
  {
    // Resize editor groups (e.g. when working with splits or chat)
    "key": "ctrl+alt+.",
    "command": "workbench.action.increaseViewSize",
  },
  {
    "key": "ctrl+alt+,",
    "command": "workbench.action.decreaseViewSize",
  },
  {
    "key": "ctrl+alt+m",
    // "command": "workbench.action.toggleMaximizeEditorGroup",
    "command": "workbench.action.toggleEditorWidths",
    "when": "editorTextFocus"
  }
]
